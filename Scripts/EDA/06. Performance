--performance analysis
WITH yearly_product_sales AS (
SELECT
YEAR(f.order_date) AS order_year,
p.product_name,
SUM(f.sales) AS total_sales
FROM gold.fact_sales f
LEFT JOIN gold.dim_product p
ON p.product_key = f.product_key
WHERE f.order_date IS NOT NULL
GROUP BY YEAR(f.order_date),
p.product_name
)

SELECT 
order_year,
product_name,
total_sales,
AVG(total_sales) OVER (PARTITION BY product_name) AS avg_sales,
total_sales - AVG(total_sales) OVER (PARTITION BY product_name) AS diff_avg,
CASE WHEN total_sales - AVG(total_sales) OVER (PARTITION BY product_name) > 0 THEN 'above average'
	 WHEN total_sales - AVG(total_sales) OVER (PARTITION BY product_name) < 0 THEN 'below average'
	 ELSE 'exactly average'
END AS flag_avg,
LAG(total_sales) OVER (PARTITION BY product_name ORDER BY order_year) AS prior_year,
total_sales - LAG(total_sales) OVER (PARTITION BY product_name ORDER BY order_year) AS diff_year_sales,
CASE WHEN total_sales - LAG(total_sales) OVER (PARTITION BY product_name ORDER BY order_year) > 0 THEN 'increased'
	 WHEN total_sales - LAG(total_sales) OVER (PARTITION BY product_name ORDER BY order_year) < 0 THEN 'decreased'
	 ELSE 'same'
	 END AS flag_prior_year
FROM yearly_product_sales
ORDER BY product_name, order_year
