/*
Purpose: Make a view of a product report with essential fields, segment the products to identify high/medium/low performers. Aggregate the data
*/
CREATE VIEW gold.product_report AS
WITH base_cte AS(
SELECT
	f.order_number,
	f.order_date,
	f.customer_key,
	f.sales,
	f.quantity,
	p.product_key,
	p.product_name,
	p.category,
	p.subcategory,
	p.cost
FROM gold.fact_sales f
LEFT JOIN gold.dim_product p
ON p.product_key = f.product_key
WHERE f.order_date IS NOT NULL
)
,
adv_cte AS(
SELECT 
	product_key,

	product_name,
	category,
	subcategory,
	cost,
	DATEDIFF(month, MIN(order_date), MAX(order_date)) AS lifespan,
	MAX(order_date) AS last_sale_date,
	COUNT(DISTINCT order_number) AS total_orders,
	COUNT(DISTINCT customer_key) AS total_customers,
	ROUND(SUM(sales), 0) AS total_sales,
	SUM(quantity) AS total_quantity,
	ROUND(AVG(CAST(sales AS FLOAT) / NULLIF(quantity, 0)), 0) AS avg_selling_price
FROM base_cte
GROUP BY 
	product_key,
	product_name,
	category,
	subcategory,
	cost
	)
SELECT
	product_key,
	product_name,
	category,
	subcategory,
	cost,
	lifespan,
	last_sale_date,
	total_orders,
	total_customers,
	total_sales,
	total_quantity,
	avg_selling_price,
	DATEDIFF(month, last_sale_date, GETDATE()) AS recency,
	CASE 
		 WHEN lifespan = 0 THEN total_sales
		 ELSE ROUND(total_sales / lifespan, 0)
	END AS avg_monthly_spend,
	CASE 
		 WHEN total_sales = 0 THEN 0
		 ELSE ROUND(total_sales / total_orders, 0)
    END AS avg_order_value,
	CASE 
		 WHEN total_sales > 50000 THEN 'High performer'
		 WHEN total_sales >= 10000 THEN 'Average performer'
		 ELSE 'Low Performer'
	END AS class
FROM adv_cte
